plugins {
    id 'java'
    id 'application'
    id 'com.gradleup.shadow' version '8.3.0'
}

group = 'com.example'
version = '1.0.0'

repositories {
    mavenCentral()
}

dependencies {
    // Oracle JDBC 驱动
    implementation 'com.oracle.database.jdbc:ojdbc11:23.3.0.23.09'
}

java {
    toolchain {
        languageVersion = JavaLanguageVersion.of(17)
    }
}

application {
    mainClass = 'com.example.JdbcDemo'
}

// 生成普通 jar 时写入 Main-Class
jar {
    manifest {
        attributes(
                'Main-Class': 'com.example.JdbcDemo'
        )
    }
}

// 生成可执行 fat jar，包含所有依赖
shadowJar {
    archiveBaseName.set('jdbc-demo')
    archiveClassifier.set('')
    archiveVersion.set('')
    mergeServiceFiles()
}