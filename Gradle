buildscript {
    repositories {
        mavenCentral()
        gradlePluginPortal()
    }
    dependencies {
        classpath 'com.gradleup.shadow:shadow-gradle-plugin:8.3.0'
    }
}

plugins {
    id 'java'
    id 'application'
}

apply plugin: 'com.gradleup.shadow'

group = 'com.example'
version = '1.0.0'

repositories {
    mavenCentral()
}

dependencies {
    // Oracle JDBC 驱动，打进 fat jar
    implementation 'com.oracle.database.jdbc:ojdbc8:23.3.0.23.09'
}

application {
    mainClass = 'com.example.JdbcDemo'
}

java {
    sourceCompatibility = JavaVersion.VERSION_11
    targetCompatibility = JavaVersion.VERSION_11
}

tasks.withType(JavaCompile).configureEach {
    options.encoding = 'UTF-8'
}

jar {
    manifest {
        attributes(
            'Main-Class': 'com.example.JdbcDemo'
        )
    }
}

shadowJar {
    archiveBaseName.set('jdbc-demo')
    archiveClassifier.set('')
    archiveVersion.set('')
    mergeServiceFiles()
}